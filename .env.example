# ─── Chutes (SN64) — inference ─────────────────────────────────────────────
CHUTES_API_KEY=cpk_...
# OpenAI-compatible LLM endpoint. Confirm in your Chutes dashboard.
CHUTES_BASE_URL=https://llm.chutes.ai/v1
# Pick any open model your Chutes account can call. Examples:
#   deepseek-ai/DeepSeek-V3  |  meta-llama/Llama-3.3-70B-Instruct  |  Qwen/Qwen2.5-72B-Instruct
CHUTES_LLM_MODEL=deepseek-ai/DeepSeek-V3
# Whisper-style transcription chute endpoint (only needed for non-YouTube uploads).
# Confirm the exact URL of the audio/whisper chute you want to use.
CHUTES_WHISPER_URL=https://chutes-whisper-large-v3.chutes.ai/transcribe

# ─── Hippius (SN75) — S3-compatible storage ────────────────────────────────
# Confirm endpoint + credentials at docs.hippius.com/storage/s3/integration
HIPPIUS_S3_ENDPOINT=https://s3.hippius.com
HIPPIUS_REGION=decentralized
HIPPIUS_ACCESS_KEY=...
HIPPIUS_SECRET_KEY=...
HIPPIUS_BUCKET=auraclip

# ─── Desearch (SN22) — optional trend lens ─────────────────────────────────
DESEARCH_API_KEY=...
DESEARCH_BASE_URL=https://apis.desearch.ai
# Toggle the trend-aware ranking boost on/off without touching code.
ENABLE_TREND_LENS=false

# ─── Limits ────────────────────────────────────────────────────────────────
# Hard cap on source length. This is the monetization seam: longer = paid tier later.
# Raise this number = the "upgrade". No code change needed when you add billing.
MAX_SOURCE_MINUTES=20
